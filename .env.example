# Copy this file to .env and fill in your real values.
# Until these are set, the app runs in MOCK MODE with seed data (no backend needed).

# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps JS API key (for the territory map - Phase 4)
VITE_GOOGLE_MAPS_KEY=

# GoHighLevel inbound webhook URL (deals get pushed here on submit - Phase 3)
VITE_GHL_WEBHOOK_URL=
